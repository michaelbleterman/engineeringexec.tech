---
interface Props {
  title: string;
  slug: string;
  date: Date;
  categories?: string[];
  description: string;
}

const { title, slug, date, categories = [], description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categoryLabels: Record<string, string> = {
  agile: "Agile",
  architecture: "Architecture",
  cloud: "Cloud",
  devops: "DevOps",
  misc: "Misc",
  "product-management": "Product Management",
  scrum: "Scrum",
  security: "Security",
  "software-development": "Software development",
  sre: "SRE",
  teammanagement: "Team Management",
  tech: "Tech",
  travel: "Travel",
};

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<article class="post-card">
  <a href={`${base}/posts/${slug}`} class="post-card-title-link">
    <h2 class="post-card-title">{title}</h2>
  </a>
  <div class="post-card-meta">
    <span class="post-card-date">{formatDate(date)}</span>
    {categories.length > 0 && (
      <>
        <span class="post-card-separator">|</span>
        {categories.map((cat, i) => (
          <>
            {i > 0 && <span class="post-card-separator">, </span>}
            <a href={`${base}/categories/${cat}`} class="post-card-category">
              {categoryLabels[cat] || cat.charAt(0).toUpperCase() + cat.slice(1)}
            </a>
          </>
        ))}
      </>
    )}
  </div>
  <p class="post-card-excerpt">{description}</p>
  <a href={`${base}/posts/${slug}`} class="post-card-read-more">Continue reading →</a>
</article>
