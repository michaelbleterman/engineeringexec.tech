---
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "Engineering leadership insights and technical strategy.",
  canonical,
  ogImage,
  ogType,
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.origin ?? "https://engineeringexec.tech";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType ?? "website"} />
    <meta property="og:site_name" content="EngineeringExec" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="EngineeringExec RSS" href={`${base}/posts/rss.xml`} />

    <!-- CookieYes consent banner -->
    <script is:inline id="cookieyes" src="https://cdn-cookieyes.com/client_data/f248354b6e968ef3c48124ac1e5bc004/script.js"></script>

    <!-- ShareThis social sharing -->
    <script is:inline src="https://platform-api.sharethis.com/js/sharethis.js#property=669f5438595beb00197dfaf8&product=sop" async></script>

    <!-- Google Consent Mode v2 defaults (must precede gtag config) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        functionality_storage: "denied",
        personalization_storage: "denied",
        security_storage: "granted",
      });
    </script>

    <!-- Google Analytics (GA4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-6Q5V3L77KW"></script>
    <script is:inline>
      gtag("js", new Date());
      gtag("config", "G-6Q5V3L77KW");
    </script>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <Sidebar />

    <main class="main-content">
      <slot />
    </main>
  </body>
</html>
