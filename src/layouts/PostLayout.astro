---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  slug: string;
  date: Date;
  updated?: Date;
  categories?: string[];
  tags?: string[];
  heroImage?: string;
  heroAlt?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  slug,
  date,
  updated,
  categories = [],
  tags = [],
  heroImage,
  heroAlt,
  ogImage,
  canonical,
} = Astro.props;

const siteUrl = Astro.site?.origin ?? "https://engineeringexec.tech";
const canonicalUrl = canonical ?? `${siteUrl}/posts/${slug}`;

const categoryLabels: Record<string, string> = {
  agile: "Agile",
  architecture: "Architecture",
  security: "Security",
  teammanagement: "Team Management",
  "software-development": "Software Development",
  "product-management": "Product Management",
  devops: "DevOps",
};

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  ...(updated && { dateModified: updated.toISOString() }),
  author: {
    "@type": "Person",
    name: "Michael Bleterman",
    url: `${siteUrl}/about`,
  },
  publisher: {
    "@type": "Organization",
    name: "EngineeringExec",
    url: siteUrl,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  ...(ogImage && { image: ogImage }),
};
---

<BaseLayout
  title={`${title} | Blog`}
  description={description}
  canonical={canonicalUrl}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article>
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {categories.length > 0 && (
          <>
            <span>|</span>
            {categories.map((cat, i) => (
              <>
                {i > 0 && <span>, </span>}
                <a href={`/categories/${cat}`}>
                  {categoryLabels[cat] || cat.charAt(0).toUpperCase() + cat.slice(1)}
                </a>
              </>
            ))}
          </>
        )}
      </div>
    </header>

    {heroImage && <img src={heroImage} alt={heroAlt ?? ""} class="hero-image" />}

    <div class="post-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <ul class="tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )}

    <div class="post-footer">
      <a href="/all-posts" class="back-to-posts">← View all posts</a>
    </div>
  </article>
</BaseLayout>
