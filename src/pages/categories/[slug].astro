---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const allCategoryLabels: Record<string, string> = {
  agile: "Agile",
  architecture: "Architecture",
  cloud: "Cloud",
  devops: "DevOps",
  misc: "Misc",
  "product-management": "Product Management",
  scrum: "Scrum",
  security: "Security",
  "software-development": "Software Development",
  sre: "SRE",
  teammanagement: "Team Management",
  tech: "Tech",
  travel: "Travel",
};

export async function getStaticPaths() {
  const labels: Record<string, string> = {
    agile: "Agile",
    architecture: "Architecture",
    cloud: "Cloud",
    devops: "DevOps",
    misc: "Misc",
    "product-management": "Product Management",
    scrum: "Scrum",
    security: "Security",
    "software-development": "Software Development",
    sre: "SRE",
    teammanagement: "Team Management",
    tech: "Tech",
    travel: "Travel",
  };

  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const allCategories = new Set([
    ...Object.keys(labels),
    ...posts.flatMap((p) => p.data.categories),
  ]);
  return [...allCategories].map((cat) => ({
    params: { slug: cat },
    props: {
      category: cat,
      posts: posts
        .filter((p) => p.data.categories.includes(cat))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
const displayName = allCategoryLabels[category] || category.charAt(0).toUpperCase() + category.slice(1);
---

<BaseLayout title={`${displayName} - EngineeringExec`} description={`Posts in ${displayName} category.`}>
  <h1 class="category-title">{displayName}</h1>
  {posts.length === 0 ? (
    <p>No items found.</p>
  ) : (
    posts.map((post) => (
      <PostCard
        title={post.data.title}
        slug={post.data.slug}
        date={post.data.date}
        categories={post.data.categories}
        description={post.data.description}
      />
    ))
  )}
</BaseLayout>
